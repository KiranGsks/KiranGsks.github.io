# UniPDI Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and stays on your machine only.

# === Supabase (public keys - safe to expose in client) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# === Razorpay (public key - safe to expose in client) ===
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_here

# === AWS Bedrock (NOTE: these are stored in browser localStorage via Settings page) ===
# AWS keys are NOT stored here — they are entered per-user in the Settings page
# and kept in the browser's localStorage only. This is intentional.
